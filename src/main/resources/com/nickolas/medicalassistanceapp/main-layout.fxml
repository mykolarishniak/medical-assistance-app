<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nickolas.medicalassistanceapp.controllers.MainController"
            stylesheets="@styles.css">

    <top>
        <HBox spacing="10" styleClass="top-bar">

            <Button text="Головна" onAction="#showHome"/>
            <Button text="Уроки" onAction="#showLessons"/>
            <Button text="Тести" onAction="#showTests"/>
            <Button text="Поради" onAction="#showAdvice"/>
            <Button text="Прогрес" onAction="#showProgress"/>
            <Button text="Адмін" onAction="#showAdmin"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="userLabel" text="Гість" styleClass="user-label"/>
            <Button text="Увійти" onAction="#openLogin" fx:id="loginBtn"/>
            <Button text="Реєстрація" onAction="#openRegister" fx:id="registerBtn"/>
            <Button text="Вийти" onAction="#logout" fx:id="logoutBtn" visible="false"/>

        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>