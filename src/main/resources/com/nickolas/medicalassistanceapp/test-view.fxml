<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<VBox spacing="25"
      alignment="TOP_CENTER"
      style="-fx-padding: 40; -fx-background-color: linear-gradient(to bottom, #e3f2fd, #bbdefb);"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nickolas.medicalassistanceapp.controllers.TestController">

    <HBox alignment="TOP_LEFT" maxWidth="Infinity">
        <Button fx:id="backButton"
                text="← Назад"
                onAction="#handleBack"
                style="
                    -fx-background-color: transparent;
                    -fx-text-fill: #1976d2;
                    -fx-font-size: 14px;
                "/>
    </HBox>

    <Label fx:id="questionLabel"
           wrapText="true"
           styleClass="question-text"/>

    <VBox fx:id="answersBox"
          spacing="15"
          maxWidth="600"/>

    <Label fx:id="resultLabel"
           styleClass="result-text"/>

</VBox>