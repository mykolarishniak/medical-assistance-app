<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>

<VBox spacing="20"
      alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nickolas.medicalassistanceapp.controllers.AdviceController"
      style="-fx-padding: 30; -fx-background-color: #f4f6f8;">

    <Label text="Медичні поради"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <TextField fx:id="symptomField"
               promptText="Введіть симптом (наприклад: болить голова)"
               maxWidth="400"/>

    <Button text="Отримати пораду"
            onAction="#handleAdvice"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>

    <TextArea fx:id="resultArea"
              wrapText="true"
              editable="false"
              prefHeight="300"
              maxWidth="500"/>

</VBox>